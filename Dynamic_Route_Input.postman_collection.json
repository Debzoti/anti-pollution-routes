            },
            "url": {
              "raw": "http://localhost:3000/api/score",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "score"]
            },
            "description": "Backend calls Ola Maps API to get routes for Mumbai"
          }
        },
